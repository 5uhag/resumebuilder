{
  "buildCommand": "npm run build --workspace client",
  "installCommand": "npm install",
  "outputDirectory": "client/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://resumebuilder-api-ordq.onrender.com/api/:path*"
    },
    {
      "source": "/health",
      "destination": "https://resumebuilder-api-ordq.onrender.com/health"
    }
  ]
}
