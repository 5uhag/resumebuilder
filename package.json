{
  "name": "resumebuilder",
  "version": "1.0.0",
  "private": true,
  "description": "MVP resume builder from PRD with PDF parsing, GitHub sync, preview, and JSON export.",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npm run build --workspace client && npm run dev --workspace server",
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npm run dev --workspace server",
    "build": "npm run build --workspace client && npm run build --workspace server",
    "start": "npm run start --workspace server"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aishu3303/resumebuilder.git"
  },
  "bugs": {
    "url": "https://github.com/aishu3303/resumebuilder/issues"
  },
  "homepage": "https://github.com/aishu3303/resumebuilder#readme",
  "devDependencies": {
    "concurrently": "^9.1.2",
    "esbuild": "0.25.5",
    "is-fullwidth-code-point": "^3.0.0"
  },
  "dependencies": {
    "mime-types": "^2.1.35"
  },
  "overrides": {
    "esbuild": "0.25.5"
  }
}
